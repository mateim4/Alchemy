{
  "name": "@alchemy-ui/core",
  "version": "1.1.0",
  "description": "A modern, tokenized design system with multi-theme support",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens": {
      "import": "./dist/tokens/index.mjs",
      "require": "./dist/tokens/index.js",
      "types": "./dist/tokens/index.d.ts"
    },
    "./css": "./dist/css/alchemy.css",
    "./css/themes/*": "./dist/css/themes/*.css",
    "./tailwind": {
      "import": "./dist/tailwind/preset.mjs",
      "require": "./dist/tailwind/preset.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:tokens && npm run build:css && npm run build:components",
    "build:tokens": "node scripts/build-tokens.mjs",
    "build:css": "node scripts/build-css.js",
    "build:components": "tsup src/components/index.ts --format esm,cjs --dts --outDir dist",
    "dev": "npm run build:tokens && tsup src/components/index.ts --format esm,cjs --dts --outDir dist --watch",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [
    "design-system",
    "tokens",
    "react",
    "tailwind",
    "css",
    "theming",
    "ui-components"
  ],
  "author": "mateim4",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateim4/Alchemy.git"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/addon-links": "^8.0.0",
    "@storybook/react": "^8.0.0",
    "@storybook/react-vite": "^8.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rimraf": "^5.0.5",
    "storybook": "^8.0.0",
    "style-dictionary": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@fluentui/react-icons": "^2.0.230",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0"
  }
}
